{
  "$schema": "https://raw.githubusercontent.com/niceda/tauri-apps/tauri-v2/tooling/cli/schema.json",
  "productName": "MindNotes",
  "version": "0.1.0",
  "identifier": "com.mindnotes.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "MindNotes",
    "windows": [
      {
        "title": "MindNotes",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
